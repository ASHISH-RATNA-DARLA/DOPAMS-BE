generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "public"), vector]
}

model Crimes {
  id                       String                       @id @map("crime_id") @db.VarChar(50)
  psCode                   String                       @map("ps_code") @db.VarChar(20)
  crimeNum                 String                       @map("fir_num") @db.VarChar(50)
  firRegNum                String                       @unique @map("fir_reg_num") @db.VarChar(50)
  firType                  String?                      @map("fir_type") @db.VarChar(50)
  sections                 String?                      @map("acts_sections")
  firDate                  DateTime?                    @map("fir_date") @db.Timestamp(6)
  caseStatus               String?                      @map("case_status") @db.VarChar(100)
  majorHead                String?                      @map("major_head") @db.VarChar(100)
  minorHead                String?                      @map("minor_head") @db.VarChar(255)
  crimeType                String?                      @map("crime_type") @db.VarChar(100)
  ioName                   String?                      @map("io_name") @db.VarChar(255)
  ioRank                   String?                      @map("io_rank") @db.VarChar(100)
  briefFacts               String?                      @map("brief_facts")
  dateCreated              DateTime?                    @map("date_created") @db.Timestamp(6)
  dateModified             DateTime?                    @map("date_modified") @db.Timestamp(6)
  caseClassification       String?                      @map("class_classification") @db.VarChar(50)
  firCopy                  String?                      @map("fir_copy") @db.VarChar(50)
  additional_json_data     Json?
  accuseds                 Accused[]
  arrests                  Arrest[]
  briefFactsAccused        BriefFactsAccused[]
  briefFactsCrimeSummaries brief_facts_crime_summaries?
  briefFactsDrugs          BriefFactsDrug[]
  chargeSheetUpdates       ChargeSheetUpdate[]
  chargesheets             Chargesheet[]
  hierarchy                Hierarchy                    @relation(fields: [psCode], references: [psCode], onUpdate: NoAction)
  disposal                 Disposal[]
  fslCaseProperty          FslCaseProperty[]
  interrogationReports     InterrogationReport[]
  moSeizures               MoSeizure[]
  oldInterragationReports  OldInterragationReport[]
  properties               Properties[]

  @@index([caseStatus], map: "idx_crimes_case_status")
  @@index([psCode], map: "idx_crimes_ps_code")
  @@index([firDate], map: "idx_crimes_fir_date")
  @@index([crimeNum], map: "idx_crimes_fir_num")
  @@index([dateCreated(sort: Desc), dateModified(sort: Desc)], map: "idx_crimes_dates")
  @@index([sections(ops: raw("gin_trgm_ops"))], map: "trgm_idx_crimes_acts_sections", type: Gin)
  @@map("crimes")
}

model Accused {
  id             String    @id @map("accused_id") @db.VarChar(50)
  crimeId        String    @map("crime_id") @db.VarChar(50)
  personId       String?   @map("person_id") @db.VarChar(50)
  code           String    @map("accused_code") @db.VarChar(20)
  type           String?   @default("Accused") @db.VarChar(50)
  seqNum         String?   @unique @map("seq_num") @db.VarChar(50)
  isCCL          Boolean?  @default(false) @map("is_ccl")
  beard          String?   @db.VarChar(100)
  build          String?   @db.VarChar(100)
  color          String?   @db.VarChar(100)
  ear            String?   @db.VarChar(100)
  eyes           String?   @db.VarChar(100)
  face           String?   @db.VarChar(100)
  hair           String?   @db.VarChar(100)
  height         String?   @db.VarChar(100)
  leucoderma     String?   @db.VarChar(100)
  mole           String?   @db.VarChar(100)
  mustache       String?   @db.VarChar(100)
  nose           String?   @db.VarChar(100)
  teeth          String?   @db.VarChar(100)
  dateCreated    DateTime? @map("date_created") @db.Timestamp(6)
  dateModified   DateTime? @map("date_modified") @db.Timestamp(6)
  accused_status String?
  crime          Crimes    @relation(fields: [crimeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  person         Persons?  @relation(fields: [personId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([crimeId], map: "idx_accused_crime")
  @@index([personId], map: "idx_accused_person")
  @@index([code], map: "idx_accused_code")
  @@index([crimeId], map: "idx_accused_crime_id")
  @@index([crimeId, personId], map: "idx_accused_crime_person")
  @@index([accused_status], map: "idx_accused_status")
  @@map("accused")
}

model Hierarchy {
  psCode       String    @id @map("ps_code") @db.VarChar(20)
  psName       String    @map("ps_name") @db.VarChar(255)
  circleCode   String?   @map("circle_code") @db.VarChar(20)
  circleName   String?   @map("circle_name") @db.VarChar(255)
  sdpoCode     String?   @map("sdpo_code") @db.VarChar(20)
  sdpoName     String?   @map("sdpo_name") @db.VarChar(255)
  subZoneCode  String?   @map("sub_zone_code") @db.VarChar(20)
  subZoneName  String?   @map("sub_zone_name") @db.VarChar(255)
  distCode     String?   @map("dist_code") @db.VarChar(20)
  distName     String?   @map("dist_name") @db.VarChar(255)
  rangeCode    String?   @map("range_code") @db.VarChar(20)
  rangeName    String?   @map("range_name") @db.VarChar(255)
  zoneCode     String?   @map("zone_code") @db.VarChar(20)
  zoneName     String?   @map("zone_name") @db.VarChar(255)
  adgCode      String?   @map("adg_code") @db.VarChar(20)
  adgName      String?   @map("adg_name") @db.VarChar(255)
  dateCreated  DateTime? @map("date_created") @db.Timestamp(6)
  dateModified DateTime? @map("date_modified") @db.Timestamp(6)
  crimes       Crimes[]

  @@map("hierarchy")
}

model Persons {
  id                         String    @id @map("person_id") @db.VarChar(50)
  name                       String?   @map("name") @db.VarChar(255)
  surname                    String?   @map("surname") @db.VarChar(255)
  alias                      String?   @map("alias") @db.VarChar(255)
  fullName                   String?   @map("full_name") @db.VarChar(500)
  relationType               String?   @map("relation_type") @db.VarChar(50)
  relativeName               String?   @map("relative_name") @db.VarChar(255)
  gender                     String?   @map("gender") @db.VarChar(20)
  isDied                     Boolean?  @default(false) @map("is_died")
  dateOfBirth                DateTime? @map("date_of_birth") @db.Date
  age                        Int?      @map("age")
  occupation                 String?   @map("occupation") @db.VarChar(255)
  educationQualification     String?   @map("education_qualification") @db.VarChar(255)
  caste                      String?   @map("caste") @db.VarChar(100)
  subCaste                   String?   @map("sub_caste") @db.VarChar(100)
  religion                   String?   @map("religion") @db.VarChar(100)
  nationality                String?   @map("nationality") @db.VarChar(100)
  designation                String?   @map("designation") @db.VarChar(255)
  placeOfWork                String?   @map("place_of_work") @db.VarChar(500)
  presentHouseNo             String?   @map("present_house_no") @db.VarChar(255)
  presentStreetRoadNo        String?   @map("present_street_road_no") @db.VarChar(255)
  presentWardColony          String?   @map("present_ward_colony") @db.VarChar(255)
  presentLandmarkMilestone   String?   @map("present_landmark_milestone") @db.VarChar(255)
  presentLocalityVillage     String?   @map("present_locality_village") @db.VarChar(255)
  presentAreaMandal          String?   @map("present_area_mandal") @db.VarChar(255)
  presentDistrict            String?   @map("present_district") @db.VarChar(255)
  presentStateUT             String?   @map("present_state_ut") @db.VarChar(255)
  presentCountry             String?   @map("present_country") @db.VarChar(255)
  presentResidencyType       String?   @map("present_residency_type") @db.VarChar(100)
  presentPinCode             String?   @map("present_pin_code") @db.VarChar(20)
  presentJurisdictionPS      String?   @map("present_jurisdiction_ps") @db.VarChar(20)
  permanentHouseNo           String?   @map("permanent_house_no") @db.VarChar(255)
  permanentStreetRoadNo      String?   @map("permanent_street_road_no") @db.VarChar(255)
  permanentWardColony        String?   @map("permanent_ward_colony") @db.VarChar(255)
  permanentLandmarkMilestone String?   @map("permanent_landmark_milestone") @db.VarChar(255)
  permanentLocalityVillage   String?   @map("permanent_locality_village") @db.VarChar(255)
  permanentAreaMandal        String?   @map("permanent_area_mandal") @db.VarChar(255)
  permanentDistrict          String?   @map("permanent_district") @db.VarChar(255)
  permanentStateUT           String?   @map("permanent_state_ut") @db.VarChar(255)
  permanentCountry           String?   @map("permanent_country") @db.VarChar(255)
  permanentResidencyType     String?   @map("permanent_residency_type") @db.VarChar(100)
  permanentPinCode           String?   @map("permanent_pin_code") @db.VarChar(20)
  permanentJurisdictionPS    String?   @map("permanent_jurisdiction_ps") @db.VarChar(20)
  phoneNumber                String?   @map("phone_number") @db.VarChar(20)
  countryCode                String?   @map("country_code") @db.VarChar(10)
  emailId                    String?   @map("email_id") @db.VarChar(255)
  dateCreated                DateTime? @map("date_created") @db.Timestamp(6)
  dateModified               DateTime? @map("date_modified") @db.Timestamp(6)
  domicile                   String?   @map("domicile_classification") @db.VarChar(50)
  rawFullName                String?   @map("raw_full_name") @db.VarChar(500)
  accusedIn                  Accused[]
  arrests                    Arrest[]

  @@index([name], map: "idx_persons_name")
  @@index([fullName], map: "idx_persons_full_name")
  @@index([phoneNumber], map: "idx_persons_phone")
  @@index([presentDistrict], map: "idx_persons_present_district")
  @@index([emailId], map: "idx_persons_email")
  @@index([id], map: "idx_persons_person_id")
  @@index([alias(ops: raw("gin_trgm_ops"))], map: "trgm_idx_persons_alias", type: Gin)
  @@index([fullName(ops: raw("gin_trgm_ops"))], map: "trgm_idx_persons_full_name", type: Gin)
  @@map("persons")
}

model Properties {
  id                   String    @id @map("property_id") @db.VarChar(50)
  crimeId              String    @map("crime_id") @db.VarChar(50)
  casePropertyId       String?   @map("case_property_id") @db.VarChar(50)
  status               String?   @map("property_status") @db.VarChar(100)
  recoveredFrom        String?   @map("recovered_from") @db.VarChar(255)
  placeOfRecovery      String?   @map("place_of_recovery")
  dateOfSeizure        DateTime? @map("date_of_seizure") @db.Timestamp(6)
  nature               String?   @map("nature") @db.VarChar(255)
  belongs              String?   @map("belongs") @db.VarChar(100)
  estimateValue        Decimal?  @default(0) @map("estimate_value") @db.Decimal(15, 2)
  recoveredValue       Decimal?  @default(0) @map("recovered_value") @db.Decimal(15, 2)
  particularOfProperty String?   @map("particular_of_property")
  category             String?   @map("category") @db.VarChar(100)
  additionalDetails    Json?     @map("additional_details")
  media                Json?     @default("[]") @map("media")
  dateCreated          DateTime? @map("date_created") @db.Timestamp(6)
  dateModified         DateTime? @map("date_modified") @db.Timestamp(6)
  crime                Crimes    @relation(fields: [crimeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([crimeId], map: "idx_properties_crime_id")
  @@index([dateOfSeizure], map: "idx_properties_date_seizure")
  @@index([additionalDetails], map: "idx_properties_additional_details_gin", type: Gin)
  @@map("properties")
}

model BriefFactsAccused {
  id                  String    @id @map("bf_accused_id") @db.Uuid
  crimeId             String    @map("crime_id") @db.VarChar(50)
  accusedId           String?   @map("accused_id") @db.VarChar(50)
  personId            String?   @map("person_id") @db.VarChar(50)
  personCode          String?   @map("person_code") @db.VarChar(50)
  seqNum              String?   @map("seq_num") @db.VarChar(50)
  fullName            String?   @map("full_name") @db.VarChar(500)
  alias               String?   @map("alias_name") @db.VarChar(255)
  age                 Int?      @map("age")
  gender              String?   @map("gender") @db.VarChar(20)
  occupation          String?   @map("occupation") @db.VarChar(255)
  address             String?   @map("address")
  phoneNumbers        String?   @map("phone_numbers") @db.VarChar(255)
  roleInCrime         String?   @map("role_in_crime")
  keyDetails          String?   @map("key_details")
  type                String?   @map("accused_type") @db.VarChar(40)
  status              String?   @map("status")
  isCCL               Boolean?  @map("is_ccl")
  sourcePersonFields  Json?     @map("source_person_fields")
  sourceAccusedFields Json?     @map("source_accused_fields")
  sourceSummaryFields Json?     @map("source_summary_fields")
  dateCreated         DateTime? @default(now()) @map("date_created") @db.Timestamp(6)
  dateModified        DateTime? @default(now()) @map("date_modified") @db.Timestamp(6)
  existing_accused    Boolean?  @default(false)
  crimes              Crimes    @relation(fields: [crimeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bf_accused_crime")

  @@unique([id, accusedId], map: "uq_bf_accused_id_accused_id")
  @@index([crimeId], map: "idx_brief_facts_accused_crime_id")
  @@index([crimeId, personId], map: "idx_brief_facts_accused_crime_person")
  @@index([accusedId], map: "idx_bf_accused_accused_id")
  @@index([crimeId], map: "idx_bf_accused_crime_id")
  @@index([personId], map: "idx_bf_accused_person_id")
  @@map("brief_facts_accused")
}

model brief_facts_crime_summaries {
  crime_id                String    @id @db.VarChar
  summary_text            String
  summary_json            Json?
  word_count              Int?
  processing_time_seconds Decimal?  @db.Decimal
  model_name              String?   @default("mistral") @db.VarChar
  date_created            DateTime? @default(now()) @db.Timestamp(6)
  date_modified           DateTime? @default(now()) @db.Timestamp(6)
  crimes                  Crimes    @relation(fields: [crime_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_summaries_crime")
}

model BriefFactsDrug {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crime_id            String    @db.VarChar(50)
  raw_drug_name       String
  raw_quantity        Decimal?  @db.Decimal(18, 6)
  raw_unit            String?
  primary_drug_name   String
  drug_form           String?
  weight_g            Decimal?  @db.Decimal(18, 6)
  weight_kg           Decimal?  @db.Decimal(18, 6)
  volume_ml           Decimal?  @db.Decimal(18, 6)
  volume_l            Decimal?  @db.Decimal(18, 6)
  count_total         Decimal?  @db.Decimal(18, 6)
  confidence_score    Decimal?  @db.Decimal(3, 2)
  extraction_metadata Json?
  is_commercial       Boolean?  @default(false)
  seizure_worth       Decimal?  @default(0.0) @db.Decimal
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  crimes              Crimes    @relation(fields: [crime_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([crime_id], map: "idx_bfd_crime_id")
  @@index([primary_drug_name], map: "idx_bfd_primary_drug")
  @@map("brief_facts_drug")
}

model PersonDeduplicationTracker {
  id                     Int       @id @default(autoincrement())
  personFingerprint      String    @unique @map("person_fingerprint") @db.VarChar(32)
  matchingTier           Int       @map("matching_tier") @db.SmallInt
  matchingStrategy       String    @map("matching_strategy") @db.VarChar(100)
  usesFuzzyMatching      Boolean?  @default(false) @map("uses_fuzzy_matching")
  fuzzyMatchScore        Decimal?  @map("fuzzy_match_score") @db.Decimal(3, 2)
  nameVariations         String[]  @map("name_variations")
  canonicalPersonId      String    @map("canonical_person_id") @db.VarChar(50)
  fullName               String?   @map("full_name") @db.VarChar(500)
  relativeName           String?   @map("relative_name") @db.VarChar(255)
  age                    Int?      @map("age")
  gender                 String?   @map("gender") @db.VarChar(20)
  phoneNumber            String?   @map("phone_number") @db.VarChar(20)
  presentDistrict        String?   @map("present_district") @db.VarChar(255)
  presentLocalityVillage String?   @map("present_locality_village") @db.VarChar(255)
  allPersonIds           String[]  @map("all_person_ids")
  personRecordCount      Int       @default(1) @map("person_record_count")
  allAccusedIds          String[]  @map("all_accused_ids")
  allCrimeIds            String[]  @map("all_crime_ids")
  crimeCount             Int       @default(0) @map("crime_count")
  crimeDetails           Json?     @map("crime_details")
  confidenceScore        Decimal?  @map("confidence_score") @db.Decimal(3, 2)
  dataQualityFlags       Json?     @map("data_quality_flags")
  createdAt              DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("person_deduplication_tracker")
}

model User {
  id              String   @id @db.Uuid
  email           String   @unique @db.VarChar(255)
  password        String   @db.VarChar(255)
  role            Int      @default(0)
  status          Int      @default(1)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)
  backgroundColor String?  @map("background_color") @db.VarChar(50)

  @@map("user")
}

